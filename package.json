{
  "name": "ionic-vue-poc",
  "private": true,
  "author": "David Prieto",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "preview:http": "vite preview --host 127.0.0.1 --port 5173",
    "prepare": "husky",
    "test:unit": "vitest run tests/unit",
    "test:render": "vitest run tests/render",
    "test:e2e": "playwright test",
    "test:perf": "npm run build && start-server-and-test preview:http http://127.0.0.1:4173 \"lhci collect --config=./lighthouserc.cjs && lhci assert --config=./lighthouserc.cjs\"",
    "test:all": "npm run test:unit && npm run test:render && npm run test:e2e",
    "perf:smoke": "playwright test tests/e2e-playwright/perf-smoke.spec.ts",
    "msw:init": "msw init public --save",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf package-lock.json .lighthouseci/ dist/ node_modules/",
    "rebuild": "npm run clean && npm install && npm run build",
    "commitlint": "commitlint --edit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.2.0",
    "@capacitor/haptics": "8.0.1",
    "@capacitor/keyboard": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@ionic/vue": "^8.8.1",
    "@ionic/vue-router": "^8.8.1",
    "ionicons": "^8.0.13",
    "msw": "^2.12.13",
    "pinia": "^3.0.4",
    "vue": "^3.3.0",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.2.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-legacy": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "start-server-and-test": "^2.1.5",
    "terser": "^5.46.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "description": "An Ionic project",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
